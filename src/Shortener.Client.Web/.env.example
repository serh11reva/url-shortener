# Origin where short links open (API host; GET /{shortCode}). Required in production builds.
# VITE_SHORT_LINK_ORIGIN=https://your-short-domain.example

# Optional: override API proxy target when running `npm run dev` (default http://localhost:5175)
# VITE_API_PROXY_TARGET=http://localhost:5175

# When using .NET Aspire (AddViteApp), the AppHost sets VITE_API_PROXY_TARGET and VITE_SHORT_LINK_ORIGIN from the API endpoint.
